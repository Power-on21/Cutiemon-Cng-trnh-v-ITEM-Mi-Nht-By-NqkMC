{
	"format_version": "1.8.0",
	"animations": {
		"animation.diglett.health_bar": {
			"loop": true,
			"bones": {
				"health_hover": {
					"rotation": ["q.camera_rotation(0)", "q.camera_rotation(1)-q.body_y_rotation", 0],
					"position": [0, 19, 0],
					"scale": "query.is_in_ui?0:1.5"
				},
				"bar_green": {
					"scale": ["query.health/query.max_health*1", 1, 1]
				},
				"bar_black": {
					"scale": ["(1)+(query.health/query.max_health*-1)", 1, 1]
				}
			}
		},
		"animation.diglett.quiet": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": ["math.sin(q.anim_time*90*2)*0.5", "math.cos(q.anim_time*90*1)*1", "math.sin(q.anim_time*90*1)*1"],
					"position": ["0.1*math.sin(q.anim_time*90*1)", "0.2*math.sin(q.anim_time*90*3)", 0]
				}
			}
		},
		"animation.diglett.attack": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": ["math.sin(q.anim_time*90*2)*3", "math.cos(q.anim_time*90*1-60)*2", "math.sin(q.anim_time*90*2)*4"],
					"position": [0, "0.2*math.sin(q.anim_time*90*4)", 0]
				},
				"body2": {
					"rotation": ["math.sin(q.anim_time*90*4-120)*3", 0, "math.sin(q.anim_time*90*2-60)*4"]
				}
			}
		},
		"animation.diglett.walk": {
			"loop": true,
			"animation_length": 4,
			"bones": {
				"body": {
					"rotation": ["4-math.sin(q.anim_time*90*6-60)*3", "0+math.cos(q.anim_time*90*6-60)*2", "0+math.cos(q.anim_time*90*3-60)*2-math.sin(q.anim_time*90*3)*3"],
					"position": ["-math.sin(q.anim_time*90*3)*0.2", "math.sin(q.anim_time*90*6)*0.5", "-0.2+math.cos(q.anim_time*90*6)*0.2"]
				},
				"ground": {
					"rotation": [0, 0, 0],
					"position": ["math.sin(q.anim_time*90*1)*0.9", 0, "-math.sin(q.anim_time*90*6-90)*0.6"]
				},
				"body2": {
					"position": [0, "math.sin(q.anim_time*90*6-30)*0.2", 0]
				}
			}
		},
		"animation.diglett.sitting": {
			"loop": true,
			"bones": {
				"body": {
					"rotation": ["7.5-1*math.sin(q.anim_time*90*1-60)", 0, "-3*math.sin(q.anim_time*90*0.5-120)"],
					"position": [0, "-0.3+0.1*math.sin(q.anim_time*90*1)", 0.25]
				},
				"eyelid_right": {
					"position": [0, 0, -0.1]
				},
				"eyelid_left": {
					"position": [0, 0, -0.1]
				},
				"body2": {
					"rotation": [0, 0, 0],
					"position": [0, -3.5, 0]
				},
				"nose": {
					"rotation": [-7, 0, 0]
				}
			}
		}
	}
}