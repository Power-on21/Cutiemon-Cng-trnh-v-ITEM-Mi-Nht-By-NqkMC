{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:chandelures_head_flame",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/pokedrock_particles"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 5
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": "((!query.is_invisible)&&query.property('serp:v')>2)*0.1"
			},
			"minecraft:emitter_shape_sphere": {
				"offset": [0, -0.15, 0],
				"radius": 0.15,
				"direction": [0, "Math.random(0,-3)", 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "Math.random(0.5, 1)"
			},
			"minecraft:particle_initial_speed": 3,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "Math.random(0,-15)", 0],
				"linear_drag_coefficient": 5
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.entity_scale*(0.2*(variable.particle_lifetime-variable.particle_age))", "v.entity_scale*(0.2*(variable.particle_lifetime-variable.particle_age))"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 8,
					"texture_height": 8,
					"uv": [3, 1],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age/v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFA700",
						"0.25": "#FFF0FF00",
						"0.5": "#FFFFA700"
					}
				}
			}
		}
	}
}