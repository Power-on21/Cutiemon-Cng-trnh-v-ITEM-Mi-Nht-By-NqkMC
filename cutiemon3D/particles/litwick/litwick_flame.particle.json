{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:litwick_flame",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/pokedrock_particles"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 3
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": "((!query.is_invisible)&&query.property('serp:v')<3)*0.1"
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, -0.15, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "Math.random(0.2, 0.7)"
			},
			"minecraft:particle_initial_speed": 1.5,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -7, 0],
				"linear_drag_coefficient": 10
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.entity_scale*(0.25*(variable.particle_lifetime-variable.particle_age))", "v.entity_scale*(0.25*(variable.particle_lifetime-variable.particle_age))"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 8,
					"texture_height": 8,
					"uv": [3, 1],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age/v.particle_lifetime",
					"gradient": {
						"0.0": "#FF6894FF",
						"0.5": "#FF5D2985"
					}
				}
			}
		}
	}
}