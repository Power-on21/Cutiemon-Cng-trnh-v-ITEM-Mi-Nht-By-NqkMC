{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:typhlosion_neck",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/flames/cyndafire"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 20
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": "((!query.is_invisible)&&query.property('serp:st')>0&&query.property('serp:st')<4)*0.1"
			},
			"minecraft:emitter_shape_point": {
				"offset": ["Math.random(0.3,-0.3)", -0.2, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "Math.random(0.15, 0.3)"
			},
			"minecraft:particle_initial_speed": 2,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "Math.random(-7.5,-15)", 0],
				"linear_drag_coefficient": 5
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.entity_scale*((v.particle_lifetime-v.particle_age)*0.85)", "v.entity_scale*((v.particle_lifetime-v.particle_age)*0.85)"],
				"facing_camera_mode": "lookat_xyz"
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age/v.particle_lifetime",
					"gradient": {
						"0.0": "#FFC00000",
						"0.75": "#FFFFBD00"
					}
				}
			}
		}
	}
}