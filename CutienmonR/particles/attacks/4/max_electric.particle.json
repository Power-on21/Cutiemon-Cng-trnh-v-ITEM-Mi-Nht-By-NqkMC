{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_electric",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 100,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.6
			},
			"minecraft:emitter_shape_point": {
				"offset": ["math.sin(variable.emitter_age*360*5)*3", 6.5, "math.cos(variable.emitter_age*360*5)*3"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.6
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random_integer(0,1)*180-45"
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -50, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.particle_age<variable.particle_lifetime?variable.particle_age:variable.particle_lifetime)*5", "(variable.particle_age<variable.particle_lifetime?variable.particle_age:variable.particle_lifetime)*5"],
				"facing_camera_mode": "rotate_y",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [3, 1],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#00FF1616",
						"0.29": "#FFFFFFFF",
						"1.0": "#00F4B1B1"
					}
				}
			}
		}
	}
}