{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_flying",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 120,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1.8
			},
			"minecraft:emitter_shape_sphere": {
				"offset": ["math.sin(variable.emitter_age*360*6)*(10-(variable.emitter_age*6))", 0.4, "math.cos(variable.emitter_age*360*6)*(10-(variable.emitter_age*6))"],
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(180,-180)",
				"rotation_rate": 1000
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "variable.particle_age<0.01?-500:5+variable.emitter_age*12", 0],
				"linear_drag_coefficient": -1
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.particle_age<0.4?0:(variable.particle_age-0.4)*variable.particle_age*8", "variable.particle_age<0.4?0:(variable.particle_age-0.4)*variable.particle_age*8"],
				"facing_camera_mode": "emitter_transform_xz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [7, 1],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_radius": 0.2
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "variable.particle_age / variable.particle_lifetime",
					"gradient": {
						"0.0": "#0000F3FF",
						"0.4": "#ffffffff",
						"1.0": "#0071EBF8"
					}
				}
			}
		}
	}
}