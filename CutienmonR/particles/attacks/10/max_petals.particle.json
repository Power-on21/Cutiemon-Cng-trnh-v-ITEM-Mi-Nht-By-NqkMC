{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_petals",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 80,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_expression": {
				"activation_expression": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": ["math.sin(variable.emitter_age*360)*variable.emitter_age*6", 0.4, "math.cos(variable.emitter_age*360)*variable.emitter_age*6"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180,180)",
				"rotation_rate": 1000
			},
			"minecraft:particle_initial_speed": 5,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "variable.particle_age<0.2?-500:60", 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.particle_age<0.2?0:variable.particle_age<variable.particle_lifetime/2?variable.particle_age:(variable.particle_lifetime-variable.particle_age))*4", "(variable.particle_age<0.2?0:variable.particle_age<variable.particle_lifetime/2?variable.particle_age:(variable.particle_lifetime-variable.particle_age))*2"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [12, 2],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_radius": 0.2
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_random_2",
					"gradient": {
						"0.0": "#FFFF0000",
						"0.5": "#FFF58BFF",
						"1.0": "#FFFFF400"
					}
				}
			}
		}
	}
}