{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_fire",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 80,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 2
			},
			"minecraft:emitter_shape_disc": {
				"offset": ["math.sin(variable.emitter_age*360)*4", "8-variable.emitter_age*12", "math.cos(variable.emitter_age*360)*4"],
				"radius": 1,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180,180)",
				"rotation_rate": 1000
			},
			"minecraft:particle_initial_speed": 5,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 10, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.particle_age<variable.particle_lifetime/2?variable.particle_age:(variable.particle_lifetime-(variable.particle_age)))*5", "(variable.particle_age<variable.particle_lifetime/2?variable.particle_age:(variable.particle_lifetime-(variable.particle_age)))*5"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [6, 1],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_random_2",
					"gradient": {
						"0.0": "#FFFD0000",
						"1.0": "#FFF0FF00"
					}
				}
			}
		}
	}
}