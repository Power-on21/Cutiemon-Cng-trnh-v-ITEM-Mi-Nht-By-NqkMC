{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:medium_fire_explosion",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 50
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.3
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, 0.5, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "Math.random(0.3, 0.6)"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-60, 60)",
				"rotation_rate": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": "Math.random(1,2)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "variable.particle_age*2", 0],
				"linear_drag_coefficient": -1
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.particle_age<variable.particle_lifetime/2?variable.particle_age:variable.particle_lifetime-variable.particle_age", "variable.particle_age<variable.particle_lifetime/2?variable.particle_age:variable.particle_lifetime-variable.particle_age"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [6, 1],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.74": "#ffffffff",
						"1.0": "#00FFFFFF"
					}
				}
			}
		}
	}
}