{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:big_bug_explosion",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 40
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, 0.5, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.3,0.6)"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(180,-180)",
				"rotation_rate": "math.random(180,-180)"
			},
			"minecraft:particle_initial_speed": "math.random(3,6)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "-variable.particle_age*10", 0],
				"linear_drag_coefficient": -1
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.particle_age<(variable.particle_lifetime/2)?variable.particle_age:variable.particle_lifetime/2", "variable.particle_age<(variable.particle_lifetime/2)?variable.particle_age:variable.particle_lifetime/2"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [12, 0],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 20,
				"collision_radius": 0.01
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.08": "#FFFFE85D",
						"0.48": "#FFB5FF65",
						"1.0": "#00384E00"
					}
				}
			}
		}
	}
}