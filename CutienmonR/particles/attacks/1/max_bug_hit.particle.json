{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_bug_hit",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 30
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, 0.5, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "Math.random(0.1, 0.6)"
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(180,-180)",
				"rotation_rate": "math.random(100,-100)"
			},
			"minecraft:particle_initial_speed": "Math.random(12,16)",
			"minecraft:particle_motion_dynamic": {
				"linear_drag_coefficient": 1.5
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(2 + v.particle_random_1*2)-(5*v.particle_age)", "(2 + v.particle_random_1*2)-(5*v.particle_age)"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [12, 0],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_drag": 20,
				"coefficient_of_restitution": 0.2,
				"collision_radius": 0.01
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FF00FF04",
						"1.0": "#00004C00"
					}
				}
			}
		}
	}
}