{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_fight",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 20,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, "10-(variable.emitter_age*15)", 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.6
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 20, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.particle_lifetime-variable.particle_age)*5", "(variable.particle_lifetime-variable.particle_age)*5"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [5, 2],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#00FFFFFF",
						"0.13": "#FFFF0000",
						"1.0": "#00000000"
					}
				}
			}
		}
	}
}