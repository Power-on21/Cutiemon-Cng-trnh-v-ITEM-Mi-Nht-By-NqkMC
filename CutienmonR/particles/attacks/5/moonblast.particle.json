				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [3, 2],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 0.1,
				"collision_radius": 0.01
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age",
