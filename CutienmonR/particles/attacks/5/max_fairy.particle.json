{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_fairy",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/star_small"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 30,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": ["math.sin(variable.emitter_age*360*10)*5", "8-(variable.emitter_age*15)", "math.cos(variable.emitter_age*360*10)*5"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.6
			},
			"minecraft:particle_initial_spin": {
				"rotation": "variable.emitter_age*90",
				"rotation_rate": 400
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 10, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.particle_lifetime-variable.particle_age)*4", "(variable.particle_lifetime-variable.particle_age)*4"],
				"facing_camera_mode": "rotate_xyz"
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#00FFFFFF",
						"0.13": "#FFFFFFFF",
						"1.0": "#00FF0DE3"
					}
				}
			}
		}
	}
}