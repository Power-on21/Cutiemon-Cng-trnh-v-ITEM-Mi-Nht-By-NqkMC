{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_ground",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 5,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, 0.5, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "variable.particle_age<0.1?(-600):0", 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.particle_age<0.2?0:(v.particle_age*v.particle_age)*15", "variable.particle_age<0.2?0:(v.particle_age*v.particle_age)*15"],
				"facing_camera_mode": "emitter_transform_xz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [0, 2],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_motion_collision": {
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age/v.particle_lifetime",
					"gradient": {
						"0.77": "#FF372000",
						"1.0": "#00432D08"
					}
				}
			}
		}
	}
}