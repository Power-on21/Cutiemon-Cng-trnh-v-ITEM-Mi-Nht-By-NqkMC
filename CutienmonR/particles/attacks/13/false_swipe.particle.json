{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:false_swipe",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 60,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.5
			},
			"minecraft:emitter_shape_point": {
				"offset": [0, "math.cos(variable.emitter_age*360)*1.5", 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": -45,
				"rotation_rate": "math.random(-100,100)"
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": ["0.3-(0.3*variable.particle_age)", "0.3-(0.3*variable.particle_age)"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [12, 2],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FF6BECFF",
						"1.0": "#00FFFFFF"
					}
				}
			}
		}
	}
}