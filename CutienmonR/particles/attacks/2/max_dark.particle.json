{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "serp:max_dark",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/attacks"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 40,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1.8
			},
			"minecraft:emitter_shape_sphere": {
				"offset": ["math.sin(variable.emitter_age*360*2)*(10-(variable.emitter_age*6))", "-1+variable.emitter_age", "math.cos(variable.emitter_age*360*2)*(10-(variable.emitter_age*6))"],
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(180,-180)",
				"rotation_rate": 1000
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 8, 0],
				"linear_drag_coefficient": -1
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["((variable.particle_age<variable.particle_lifetime/2)?variable.particle_age:variable.particle_lifetime-(variable.particle_age))*3", "((variable.particle_age<variable.particle_lifetime/2)?variable.particle_age:variable.particle_lifetime-(variable.particle_age))*3"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 18,
					"texture_height": 4,
					"uv": [1, 2],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_random_2",
					"gradient": {
						"0.0": "#FF000633",
						"0.5": "#FFB100FF",
						"1.0": "#FF45002A"
					}
				}
			}
		}
	}
}