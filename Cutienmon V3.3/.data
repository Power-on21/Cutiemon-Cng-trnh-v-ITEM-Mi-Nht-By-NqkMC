ibution\\\":\\\"uniform\\\"},\\\"scatter_chance\\\":{\\\"numerator\\\":40,\\\"denominator\\\":100}}\"}}","display_name":"Structure","group_id":"root","type":"structure","create_time":"2026-01-10T02:56:35.777"},{"item_id":"recipes_3bfd5363","item_name":"7fd211c2","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_furnace":{"tags":["furnace"],"output":{"item":"serp:potion","data":0},"input":{"item":"serp:unrefined_potion","data":0},"description":{"identifier":"recipes_3bfd5363"}}},"shapeType":"furnace","idRecipes":"serp:potion"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["|pa|serp_unrefined_potion","",""],["","",""],["","",""]],"lock":true,"display_name":"Recipe","group_id":"root","type":"recipe","create_time":"2025-10-26T15:43:25.499"},{"item_id":"recipes_4a1650d8","item_name":"cfb9c3af","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_furnace":{"tags":["campfire","soul_campfire"],"output":{"item":"serp:potion","data":0},"input":{"item":"serp:unrefined_potion","data":0},"description":{"identifier":"recipes_4a1650d8"}}},"shapeType":"campfire","idRecipes":"serp:potion"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["|pa|serp_unrefined_potion","|pa|serp_unrefined_potion",""],["","",""],["","",""]],"lock":true,"display_name":"Recipe","group_id":"root","type":"recipe","create_time":"2025-10-26T15:43:25.499"},{"item_id":"recipes_96a9d18f","item_name":"750ee7d6","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_furnace":{"tags":["campfire","soul_campfire"],"output":{"item":"serp:super_potion","data":0},"input":{"item":"serp:unrefined_superpotion","data":0},"description":{"identifier":"recipes_96a9d18f"}}},"shapeType":"campfire","idRecipes":"serp:super_potion"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["|pa|serp_unrefined_superpotion","",""],["","",""],["","",""]],"lock":true,"display_name":"Recipe","group_id":"root","type":"recipe","create_time":"2025-10-26T15:43:25.499"},{"item_id":"recipes_a043a7c3","item_name":"9605c6ad","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_furnace":{"tags":["furnace"],"output":{"item":"serp:super_potion","data":0},"input":{"item":"serp:unrefined_superpotion","data":0},"description":{"identifier":"recipes_a043a7c3"},"unlock":[{"item":"serp:unrefined_potion"}]}},"shapeType":"furnace","idRecipes":"serp:super_potion"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["|pa|serp_unrefined_superpotion","",""],["","",""],["","",""]],"lock":true,"display_name":"Recipe","group_id":"root","type":"recipe","create_time":"2025-10-26T15:43:25.499"},{"item_id":"recipes_d8c710eb","item_name":"03bdfb74","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_furnace":{"tags":["furnace"],"output":{"item":"serp:hyper_potion","data":0},"input":{"item":"serp:unrefined_hyperpotion","data":0},"description":{"identifier":"recipes_d8c710eb"}}},"shapeType":"furnace","idRecipes":"serp:hyper_potion"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["|pa|serp_unrefined_hyperpotion","",""],["","",""],["","",""]],"lock":true,"display_name":"Recipe","group_id":"root","type":"recipe","create_time":"2025-10-26T15:43:25.499"},{"item_id":"recipes_d8ca1bfe","item_name":"663f3d0e","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_furnace":{"tags":["campfire","soul_campfire"],"output":{"item":"serp:hyper_potion","data":0},"input":{"item":"serp:unrefined_hyperpotion","data":0},"description":{"identifier":"recipes_d8ca1bfe"}}},"shapeType":"campfire","idRecipes":"serp:hyper_potion"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["|pa|serp_unrefined_hyperpotion","",""],["","",""],["","",""]],"lock":true,"display_name":"Recipe","group_id":"root","type":"recipe","create_time":"2025-10-26T15:43:25.499"},{"item_id":"rotomphone","item_name":"rotomphone","item_icon":"custom/scripts.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"scripts/scripts.json","item_skin":"","data":{"name":"rotomphone","scripts":"import { world, system } from '@minecraft/server';\nimport { ActionFormData, ModalFormData } from '@minecraft/server-ui';\n\nfunction rotomPhone(player) {\nconst form = new ActionFormData()\n.title('serp.main.rotom_phone.list')\n.button(\"Storage PC\", 'textures/ui/stg/changebox')\n.button(\"PokeBank\", \"pokeitems/items/poke/money\");\n\ntry { player.playSound(\"custom_sound.open_phone\"); } catch (e) { console.error(e); }\n\nform.show(player).then(response => {\nif (response.canceled) {\ntry { player.playSound(\"custom_sound.close_phone\"); } catch (e) { console.error(e); }\nreturn;\n}\n\nif (response.selection === 0) {  \n  pcSystem(player, 1, true);  \n}  \nif (response.selection === 1) {  \n  bankSystem(player);  \n}\n\n});\n}\n\nfunction pcSystem(player, boxIndex, firstOpen) {\nconst offset = 0x19 * boxIndex - 0x19;\nconst forms = ['', '', '', '', ''];\nconst tags = player.getTags().filter(t => t.startsWith('stg'));\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone.grid\")\n.body(\"Rotom Phone | Storage PC,  \" + boxIndex);\n\nfor (let i = 0; i < 0x19; i++) {\nconst tag = tags[i + offset];\nif (tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst level = Math.floor(parts[8] / 100);\nform.button(forms[parts[3] - 1] + \"\\nLv. \" + level, 'pokeitems/items/icons/' + (parts[3] >= 3 ? name + 's' : name));\n} else {\nform.button('');\n}\n}\n\nform.button('', \"textures/ui/stg/changebox\");\n\nif (firstOpen) {\nplayer.playSound(\"mob.pc.boot_on\");\n}\n\nform.show(player).then(response => {\nconst tag = tags[response.selection + offset];\nif (response.canceled) {\nplayer.playSound('serp.market.store');\nreturn;\n}\nif (response.selection === 0x19) {\npcChangeBox(player, boxIndex);\nreturn;\n}\nif (!tag) {\npcSystem(player, boxIndex, false);\nreturn;\n}\npcSelectPoke(player, boxIndex, tag);\n});\n}\n\nfunction pcSelectPoke(player, boxIndex, tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst forms = ['', '', '', '', ''];\nconst level = Math.floor(parts[8] / 100);\nconst ability = parts[10];\nconst nature = parts[9];\nconst held = parts[11];\nconst display = parts[3] >= 3 ? name + 's' : name;\n\nconst form = new ActionFormData()\n.title(\"serp.main.stg.list\")\n.body({\n'rawtext': [\n{ 'text': '´' },\n{ 'translate': \"entity.pokemon:p\" + name + \".name\" },\n{ 'text': forms[parts[3] - 1] + \"Lv. \" + level + \"  \" },\n{ 'translate': \"equippable.\" + held },\n{ 'text': \"\\n \" },\n{ 'translate': \"nature.\" + nature },\n{ 'text': \"  \" },\n{ 'translate': \"ability.\" + ability },\n{ 'text': \"\\n\\nSimple information\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\" }\n]\n})\n.button({ 'translate': 'serp.to_team' }, \"textures/ui/stg/toteam\")\n.button({ 'translate': \"serp.release\" }, \"textures/ui/stg/release\")\n.button(\"serp.sprite\", \"textures/pokedex/\" + display);\n\nform.show(player).then(response => {\nif (response.canceled) {\npcSystem(player, boxIndex, false);\nreturn;\n}\nif (response.selection === 0) {\nconst getTeamSlot = n => player.getTags().find(t => t.startsWith(\"team\" + n));\nlet slot = null;\nfor (let i = 1; i <= 6; i++) {\nif (!getTeamSlot(i)) {\nslot = i;\nbreak;\n}\n}\nif (slot === null) {\nplayer.sendMessage({ 'translate': \"serp.full_team\" });\nreturn;\n}\nplayer.sendMessage({\n'rawtext': [\n{ 'translate': 'serp.welcome_back' },\n{ 'translate': \"entity.pokemon:p\" + name + \".name\" }\n]\n});\nplayer.addTag(\"team\" + slot + '/' + parts.slice(1).join('/'));\nplayer.removeTag(tag);\n}\nif (response.selection === 1) {\nplayer.sendMessage({\n'rawtext': [\n{ 'translate': \"serp.goodbye_stg\" },\n{ 'translate': \"entity.pokemon:p\" + name + '.name' }\n]\n});\nplayer.removeTag(tag);\n}\n});\n}\n\nfunction pcChangeBox(player, currentBox) {\nconst form = new ActionFormData().title(\"serp.main.rotom_phone.list\");\nfor (let i = 0; i < 10; i++) {\nform.button({\n'rawtext': [\n{ 'translate': 'serp.change_box' },\n{ 'text': '' + (i + 1) }\n]\n}, \"textures/ui/stg/changebox\");\n}\nform.show(player).then(response => {\nif (response.canceled) {\npcSystem(player, currentBox, false);\nreturn;\n}\npcSystem(player, response.selection + 1, false);\n});\n}\n\nfunction bankSystem(player) {\nconst moneyObj = world.scoreboard.getObjective('money');\nconst score = moneyObj.getScore(player.scoreboardIdentity);\nconst saved = Number(player.getDynamicProperty('wallet') ?? 0);\n\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone.list\")\n.body(\"Tus ahorros están seguros aquí\\n\\nSaldo disponible:\" + score + \"\\n§dTotal guardado: \" + saved + \"\\n\")\n.button(\"Guardar\", 'textures/icon/icon_import')\n.button('Retirar', 'textures/icon/icon_export');\n\nform.show(player).then(response => {\nif (response.canceled) return;\n\nif (response.selection === 0) {  \n  const saveForm = new ModalFormData()  \n    .title(\"Guardar dinero\")  \n    .label(\"§aSaldo disponible: \" + score)  \n    .label(\"§9Total guardado: \" + saved)  \n    .textField(\"Introduce la cantidad que deseas ahorrar en tu cuenta bancaria\", \"Introduce un número\")  \n    .submitButton(\"Guardar\");  \n\n  saveForm.show(player).then(r => {  \n    if (r.canceled) return;  \n    const amount = Number(r.formValues[2]);  \n    if (isNaN(amount)) return player.sendMessage(\"§cIntroduzca solo números\");  \n    if (amount <= 0) return player.sendMessage(\"§cIntroduzca un valor mayor que cero\");  \n    if (amount > score) return player.sendMessage(\"§cNo dispones de esa cantidad\");  \n\n    player.setDynamicProperty(\"wallet\", '' + (saved + amount));  \n    moneyObj.setScore(player.scoreboardIdentity, score - amount);  \n    player.sendMessage(\"§aGuardaste \" + amount + \" en tu banco!\");  \n  });  \n}  \n\nif (response.selection === 1) {  \n  const withdrawForm = new ModalFormData()  \n    .title(\"Retirar dinero\")  \n    .label(\"§aSaldo disponible: \" + score)  \n    .label(\"§9Total guardado: \" + saved)  \n    .textField(\"Introduzca la cantidad que desea retirar de su banco\", \"Introduce un número\")  \n    .submitButton(\"Retirar\");  \n\n  withdrawForm.show(player).then(r => {  \n    if (r.canceled) return;  \n    const amount = Number(r.formValues[2]);  \n    if (isNaN(amount)) return player.sendMessage(\"§cIntroduzca solo números\");  \n    if (amount <= 0) return player.sendMessage(\"§cIntroduzca un valor mayor que cero\");  \n    if (amount > saved) return player.sendMessage(\"§cNo tienes esa cantidad ahorrada\");  \n\n    player.setDynamicProperty(\"wallet\", '' + (saved - amount));  \n    moneyObj.setScore(player.scoreboardIdentity, score + amount);  \n    player.sendMessage(\"§aRetiraste \" + amount + \" de tu banco!\");  \n  });  \n}\n\n});\n}\n\nworld.afterEvents.itemUse.subscribe(ev => {\nif (ev.itemStack.typeId === 'serp:rotomphone') {\nrotomPhone(ev.source);\n}\n});"},"premium":false,"premium_users_only":false,"disable":false,"lock":true,"display_name":"Scripts","group_id":"root","type":"scripts","create_time":"2025-11-11T15:59:20.522"},{"item_id":"rotomphone_black","item_name":"rotomphone_black","item_icon":"custom/scripts.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"scripts/scripts.json","item_skin":"","data":{"name":"rotomphone_black","scripts":"import { world, system } from '@minecraft/server';\nimport { ActionFormData, ModalFormData } from '@minecraft/server-ui';\n\nfunction rotomPhone(player) {\nconst form = new ActionFormData()\n.title('serp.main.rotom_phone_black.list')\n.button(\"Storage PC\", 'textures/ui/stg/changebox')\n.button(\"PokeBank\", \"pokeitems/items/poke/money\");\n\ntry { player.playSound(\"custom_sound.open_phone\"); } catch (e) { console.error(e); }\n\nform.show(player).then(response => {\nif (response.canceled) {\ntry { player.playSound(\"custom_sound.close_phone\"); } catch (e) { console.error(e); }\nreturn;\n}\n\nif (response.selection === 0) {  \n  pcSystem(player, 1, true);  \n}  \nif (response.selection === 1) {  \n  bankSystem(player);  \n}\n\n});\n}\n\nfunction pcSystem(player, boxIndex, firstOpen) {\nconst offset = 0x19 * boxIndex - 0x19;\nconst forms = ['', '', '', '', ''];\nconst tags = player.getTags().filter(t => t.startsWith('stg'));\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone_black.grid\")\n.body(\"Rotom Phone | Storage PC,  \" + boxIndex);\n\nfor (let i = 0; i < 0x19; i++) {\nconst tag = tags[i + offset];\nif (tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst level = Math.floor(parts[8] / 100);\nform.button(forms[parts[3] - 1] + \"\\nLv. \" + level, 'pokeitems/items/icons/' + (parts[3] >= 3 ? name + 's' : name));\n} else {\nform.button('');\n}\n}\n\nform.button('', \"textures/ui/stg/changebox\");\n\nif (firstOpen) {\nplayer.playSound(\"mob.pc.boot_on\");\n}\n\nform.show(player).then(response => {\nconst tag = tags[response.selection + offset];\nif (response.canceled) {\nplayer.playSound('serp.market.store');\nreturn;\n}\nif (response.selection === 0x19) {\npcChangeBox(player, boxIndex);\nreturn;\n}\nif (!tag) {\npcSystem(player, boxIndex, false);\nreturn;\n}\npcSelectPoke(player, boxIndex, tag);\n});\n}\n\nfunction pcSelectPoke(player, boxIndex, tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst forms = ['', '', '', '', ''];\nconst level = Math.floor(parts[8] / 100);\nconst ability = parts[10];\nconst nature = parts[9];\nconst held = parts[11];\nconst display = parts[3] >= 3 ? name + 's' : name;\n\nconst form = new ActionFormData()\n.title(\"serp.main.stg.list\")\n.body({\n'rawtext': [\n{ 'text': '´' },\n{ 'translate': \"entity.pokemon:p\" + name + \".name\" },\n{ 'text': forms[parts[3] - 1] + \"Lv. \" + level + \"  \" },\n{ 'translate': \"equippable.\" + held },\n{ 'text': \"\\n \" },\n{ 'translate': \"nature.\" + nature },\n{ 'text': \"  \" },\n{ 'translate': \"ability.\" + ability },\n{ 'text': \"\\n\\nSimple information\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\" }\n]\n})\n.button({ 'translate': 'serp.to_team' }, \"textures/ui/stg/toteam\")\n.button({ 'translate': \"serp.release\" }, \"textures/ui/stg/release\")\n.button(\"serp.sprite\", \"textures/pokedex/\" + display);\n\nform.show(player).then(response => {\nif (response.canceled) {\npcSystem(player, boxIndex, false);\nreturn;\n}\nif (response.selection === 0) {\nconst getTeamSlot = n => player.getTags().find(t => t.startsWith(\"team\" + n));\nlet slot = null;\nfor (let i = 1; i <= 6; i++) {\nif (!getTeamSlot(i)) {\nslot = i;\nbreak;\n}\n}\nif (slot === null) {\nplayer.sendMessage({ 'translate': \"serp.full_team\" });\nreturn;\n}\nplayer.sendMessage({\n'rawtext': [\n{ 'translate': 'serp.welcome_back' },\n{ 'translate': \"entity.pokemon:p\" + name + \".name\" }\n]\n});\nplayer.addTag(\"team\" + slot + '/' + parts.slice(1).join('/'));\nplayer.removeTag(tag);\n}\nif (response.selection === 1) {\nplayer.sendMessage({\n'rawtext': [\n{ 'translate': \"serp.goodbye_stg\" },\n{ 'translate': \"entity.pokemon:p\" + name + '.name' }\n]\n});\nplayer.removeTag(tag);\n}\n});\n}\n\nfunction pcChangeBox(player, currentBox) {\nconst form = new ActionFormData().title(\"serp.main.rotom_phone_black.list\");\nfor (let i = 0; i < 10; i++) {\nform.button({\n'rawtext': [\n{ 'translate': 'serp.change_box' },\n{ 'text': '' + (i + 1) }\n]\n}, \"textures/ui/stg/changebox\");\n}\nform.show(player).then(response => {\nif (response.canceled) {\npcSystem(player, currentBox, false);\nreturn;\n}\npcSystem(player, response.selection + 1, false);\n});\n}\n\nfunction bankSystem(player) {\nconst moneyObj = world.scoreboard.getObjective('money');\nconst score = moneyObj.getScore(player.scoreboardIdentity);\nconst saved = Number(player.getDynamicProperty('wallet') ?? 0);\n\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone_black.list\")\n.body(\"Tus ahorros están seguros aquí\\n\\nSaldo disponible:\" + score + \"\\n§dTotal guardado: \" + saved + \"\\n\")\n.button(\"Guardar\", 'textures/icon/icon_import')\n.button('Retirar', 'textures/icon/icon_export');\n\nform.show(player).then(response => {\nif (response.canceled) return;\n\nif (response.selection === 0) {  \n  const saveForm = new ModalFormData()  \n    .title(\"Guardar dinero\")  \n    .label(\"§aSaldo disponible: \" + score)  \n    .label(\"§9Total guardado: \" + saved)  \n    .textField(\"Introduce la cantidad que deseas ahorrar en tu cuenta bancaria\", \"Introduce un número\")  \n    .submitButton(\"Guardar\");  \n\n  saveForm.show(player).then(r => {  \n    if (r.canceled) return;  \n    const amount = Number(r.formValues[2]);  \n    if (isNaN(amount)) return player.sendMessage(\"§cIntroduzca solo números\");  \n    if (amount <= 0) return player.sendMessage(\"§cIntroduzca un valor mayor que cero\");  \n    if (amount > score) return player.sendMessage(\"§cNo dispones de esa cantidad\");  \n\n    player.setDynamicProperty(\"wallet\", '' + (saved + amount));  \n    moneyObj.setScore(player.scoreboardIdentity, score - amount);  \n    player.sendMessage(\"§aGuardaste \" + amount + \" en tu banco!\");  \n  });  \n}  \n\nif (response.selection === 1) {  \n  const withdrawForm = new ModalFormData()  \n    .title(\"Retirar dinero\")  \n    .label(\"§aSaldo disponible: \" + score)  \n    .label(\"§9Total guardado: \" + saved)  \n    .textField(\"Introduzca la cantidad que desea retirar de su banco\", \"Introduce un número\")  \n    .submitButton(\"Retirar\");  \n\n  withdrawForm.show(player).then(r => {  \n    if (r.canceled) return;  \n    const amount = Number(r.formValues[2]);  \n    if (isNaN(amount)) return player.sendMessage(\"§cIntroduzca solo números\");  \n    if (amount <= 0) return player.sendMessage(\"§cIntroduzca un valor mayor que cero\");  \n    if (amount > saved) return player.sendMessage(\"§cNo tienes esa cantidad ahorrada\");  \n\n    player.setDynamicProperty(\"wallet\", '' + (saved - amount));  \n    moneyObj.setScore(player.scoreboardIdentity, score + amount);  \n    player.sendMessage(\"§aRetiraste \" + amount + \" de tu banco!\");  \n  });  \n}\n\n});\n}\n\nworld.afterEvents.itemUse.subscribe(ev => {\nif (ev.itemStack.typeId === 'serp:rotomphone_black') {\nrotomPhone(ev.source);\n}\n});"},"premium":false,"premium_users_only":false,"disable":false,"lock":true,"display_name":"Scripts","group_id":"root","type":"scripts","create_time":"2025-11-13T16:20:21.158"},{"item_id":"rotomphone_blue","item_name":"rotomphone_blue","item_icon":"custom/scripts.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"scripts/scripts.json","item_skin":"","data":{"name":"rotomphone_blue","scripts":"import { world, system } from '@minecraft/server';\nimport { ActionFormData, ModalFormData } from '@minecraft/server-ui';\n\nfunction rotomPhone(player) {\nconst form = new ActionFormData()\n.title('serp.main.rotom_phone_blue.list')\n.button(\"Storage PC\", 'textures/ui/stg/changebox')\n.button(\"PokeBank\", \"pokeitems/items/poke/money\");\n\ntry { player.playSound(\"custom_sound.open_phone\"); } catch (e) { console.error(e); }\n\nform.show(player).then(response => {\nif (response.canceled) {\ntry { player.playSound(\"custom_sound.close_phone\"); } catch (e) { console.error(e); }\nreturn;\n}\n\nif (response.selection === 0) {  \n  pcSystem(player, 1, true);  \n}  \nif (response.selection === 1) {  \n  bankSystem(player);  \n}\n\n});\n}\n\nfunction pcSystem(player, boxIndex, firstOpen) {\nconst offset = 0x19 * boxIndex - 0x19;\nconst forms = ['', '', '', '', ''];\nconst tags = player.getTags().filter(t => t.startsWith('stg'));\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone_blue.grid\")\n.body(\"Rotom Phone | Storage PC,  \" + boxIndex);\n\nfor (let i = 0; i < 0x19; i++) {\nconst tag = tags[i + offset];\nif (tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst level = Math.floor(parts[8] / 100);\nform.button(forms[parts[3] - 1] + \"\\nLv. \" + level, 'pokeitems/items/icons/' + (parts[3] >= 3 ? name + 's' : name));\n} else {\nform.button('');\n}\n}\n\nform.button('', \"textures/ui/stg/changebox\");\n\nif (firstOpen) {\nplayer.playSound(\"mob.pc.boot_on\");\n}\n\nform.show(player).then(response => {\nconst tag = tags[response.selection + offset];\nif (response.canceled) {\nplayer.playSound('serp.market.store');\nreturn;\n}\nif (response.selection === 0x19) {\npcChangeBox(player, boxIndex);\nreturn;\n}\nif (!tag) {\npcSystem(player, boxIndex, false);\nreturn;\n}\npcSelectPoke(player, boxIndex, tag);\n});\n}\n\nfunction pcSelectPoke(player, boxIndex, tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst forms = ['', '', '', '', ''];\nconst level = Math.floor(parts[8] / 100);\nconst ability = parts[10];\nconst nature = parts[9];\nconst held = parts[11];\nconst display = parts[3] >= 3 ? name + 's' : name;\n\nconst form = new ActionFormData()\n.title(\"serp.main.stg.list\")\n.body({\n'rawtext': [\n{ 'text': '´' },\n{ 'translate': \"entity.pokemon:p\" + name + \".name\" },\n{ 'text': forms[parts[3] - 1] + \"Lv. \" + level + \"  \" },\n{ 'translate': \"equippable.\" + held },\n{ 'text': \"\\n \" },\n{ 'translate': \"nature.\" + nature },\n{ 'text': \"  \" },\n{ 'translate': \"ability.\" + ability },\n{ 'text': \"\\n\\nSimple information\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\" }\n]\n})\n.button({ 'translate': 'serp.to_team' }, \"textures/ui/stg/toteam\")\n.button({ 'translate': \"serp.release\" }, \"textures/ui/stg/release\")\n.button(\"serp.sprite\", \"textures/pokedex/\" + display);\n\nform.show(player).then(response => {\nif (response.canceled) {\npcSystem(player, boxIndex, false);\nreturn;\n}\nif (response.selection === 0) {\nconst getTeamSlot = n => player.getTags().find(t => t.startsWith(\"team\" + n));\nlet slot = null;\nfor (let i = 1; i <= 6; i++) {\nif (!getTeamSlot(i)) {\nslot = i;\nbreak;\n}\n}\nif (slot === null) {\nplayer.sendMessage({ 'translate': \"serp.full_team\" });\nreturn;\n}\nplayer.sendMessage({\n'rawtext': [\n{ 'translate': 'serp.welcome_back' },\n{ 'translate': \"entity.pokemon:p\" + name + \".name\" }\n]\n});\nplayer.addTag(\"team\" + slot + '/' + parts.slice(1).join('/'));\nplayer.removeTag(tag);\n}\nif (response.selection === 1) {\nplayer.sendMessage({\n'rawtext': [\n{ 'translate': \"serp.goodbye_stg\" },\n{ 'translate': \"entity.pokemon:p\" + name + '.name' }\n]\n});\nplayer.removeTag(tag);\n}\n});\n}\n\nfunction pcChangeBox(player, currentBox) {\nconst form = new ActionFormData().title(\"serp.main.rotom_phone_blue.list\");\nfor (let i = 0; i < 10; i++) {\nform.button({\n'rawtext': [\n{ 'translate': 'serp.change_box' },\n{ 'text': '' + (i + 1) }\n]\n}, \"textures/ui/stg/changebox\");\n}\nform.show(player).then(response => {\nif (response.canceled) {\npcSystem(player, currentBox, false);\nreturn;\n}\npcSystem(player, response.selection + 1, false);\n});\n}\n\nfunction bankSystem(player) {\nconst moneyObj = world.scoreboard.getObjective('money');\nconst score = moneyObj.getScore(player.scoreboardIdentity);\nconst saved = Number(player.getDynamicProperty('wallet') ?? 0);\n\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone_blue.list\")\n.body(\"Tus ahorros están seguros aquí\\n\\nSaldo disponible:\" + score + \"\\n§dTotal guardado: \" + saved + \"\\n\")\n.button(\"Guardar\", 'textures/icon/icon_import')\n.button('Retirar', 'textures/icon/icon_export');\n\nform.show(player).then(response => {\nif (response.canceled) return;\n\nif (response.selection === 0) {  \n  const saveForm = new ModalFormData()  \n    .title(\"Guardar dinero\")  \n    .label(\"§aSaldo disponible: \" + score)  \n    .label(\"§9Total guardado: \" + saved)  \n    .textField(\"Introduce la cantidad que deseas ahorrar en tu cuenta bancaria\", \"Introduce un número\")  \n    .submitButton(\"Guardar\");  \n\n  saveForm.show(player).then(r => {  \n    if (r.canceled) return;  \n    const amount = Number(r.formValues[2]);  \n    if (isNaN(amount)) return player.sendMessage(\"§cIntroduzca solo números\");  \n    if (amount <= 0) return player.sendMessage(\"§cIntroduzca un valor mayor que cero\");  \n    if (amount > score) return player.sendMessage(\"§cNo dispones de esa cantidad\");  \n\n    player.setDynamicProperty(\"wallet\", '' + (saved + amount));  \n    moneyObj.setScore(player.scoreboardIdentity, score - amount);  \n    player.sendMessage(\"§aGuardaste \" + amount + \" en tu banco!\");  \n  });  \n}  \n\nif (response.selection === 1) {  \n  const withdrawForm = new ModalFormData()  \n    .title(\"Retirar dinero\")  \n    .label(\"§aSaldo disponible: \" + score)  \n    .label(\"§9Total guardado: \" + saved)  \n    .textField(\"Introduzca la cantidad que desea retirar de su banco\", \"Introduce un número\")  \n    .submitButton(\"Retirar\");  \n\n  withdrawForm.show(player).then(r => {  \n    if (r.canceled) return;  \n    const amount = Number(r.formValues[2]);  \n    if (isNaN(amount)) return player.sendMessage(\"§cIntroduzca solo números\");  \n    if (amount <= 0) return player.sendMessage(\"§cIntroduzca un valor mayor que cero\");  \n    if (amount > saved) return player.sendMessage(\"§cNo tienes esa cantidad ahorrada\");  \n\n    player.setDynamicProperty(\"wallet\", '' + (saved - amount));  \n    moneyObj.setScore(player.scoreboardIdentity, score + amount);  \n    player.sendMessage(\"§aRetiraste \" + amount + \" de tu banco!\");  \n  });  \n}\n\n});\n}\n\nworld.afterEvents.itemUse.subscribe(ev => {\nif (ev.itemStack.typeId === 'serp:rotomphone_blue') {\nrotomPhone(ev.source);\n}\n});"},"premium":false,"premium_users_only":false,"disable":false,"lock":true,"display_name":"Scripts","group_id":"root","type":"scripts","create_time":"2025-11-13T14:09:43.444"},{"item_id":"rotomphone_lime","item_name":"rotomphone_lime","item_icon":"custom/scripts.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"scripts/scripts.json","item_skin":"","data":{"name":"rotomphone_lime","scripts":"import { world, system } from '@minecraft/server';\nimport { ActionFormData, ModalFormData } from '@minecraft/server-ui';\n\nfunction rotomPhone(player) {\nconst form = new ActionFormData()\n.title('serp.main.rotom_phone_lime.list')\n.button(\"Storage PC\", 'textures/ui/stg/changebox')\n.button(\"PokeBank\", \"pokeitems/items/poke/money\");\n\ntry { player.playSound(\"custom_sound.open_phone\"); } catch (e) { console.error(e); }\n\nform.show(player).then(response => {\nif (response.canceled) {\ntry { player.playSound(\"custom_sound.close_phone\"); } catch (e) { console.error(e); }\nreturn;\n}\n\nif (response.selection === 0) {  \n  pcSystem(player, 1, true);  \n}  \nif (response.selection === 1) {  \n  bankSystem(player);  \n}\n\n});\n}\n\nfunction pcSystem(player, boxIndex, firstOpen) {\nconst offset = 0x19 * boxIndex - 0x19;\nconst forms = ['', '', '', '', ''];\nconst tags = player.getTags().filter(t => t.startsWith('stg'));\nconst form = new ActionFormData()\n.title(\"serp.main.rotom_phone_lime.grid\")\n.body(\"Rotom Phone | Storage PC,  \" + boxIndex);\n\nfor (let i = 0; i < 0x19; i++) {\nconst tag = tags[i + offset];\nif (tag) {\nconst parts = tag.split('/');\nconst name = parts[2];\nconst 