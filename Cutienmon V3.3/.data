e9a33"},"tags":["cooking_pot"],"pattern":["AB"," C"],"key":{"A":{"item":"minecraft:green_dye","data":0},"B":{"item":"minecraft:sugar","data":0},"C":{"item":"serp:moomoo_milk","data":0}},"result":{"item":"serp:green_edible_dye","count":1}}},"shapeType":"cooking_pot","idRecipes":"serp:green_edible_dye","applyCraftTable":"false"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["","",""],["|pa|minecraft_green_dye","|pa|minecraft_sugar",""],["","|pa|serp_moomoo_milk",""]],"lock":true,"display_name":"Recipes","group_id":"root","type":"recipe","create_time":"2026-01-11T18:46:13.407"},{"item_id":"c81368e9","item_name":"Recipes","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_shaped":{"description":{"identifier":"recipes_0dfa34a3"},"tags":["crafting_table"],"pattern":["BC"],"key":{"B":{"item":"serp:dynamax_band","data":0},"C":{"item":"minecraft:red_dye","data":0}},"result":{"item":"serp:dynamax_band_red","count":1}}},"shapeType":"shaped","idRecipes":"serp:dynamax_band_red"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["","",""],["","|pa|serp_dynamax_band","|pa|minecraft_red_dye"],["","",""]],"lock":true,"display_name":"Recipes","group_id":"root","type":"recipe","create_time":"2025-11-24T15:56:21.648"},{"item_id":"c9241ee7","item_name":"Recipes","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"entities/items/recipes.json","item_skin":"","entities":{"format_version":"1.10","minecraft:item":{"description":{"identifier":"","category":"items"},"components":{"minecraft:hand_equipped":false,"minecraft:max_stack_size":64,"minecraft:foil":false,"minecraft:stack_by_data":true}}},"data":{"recipes":{"format_version":"1.12","minecraft:recipe_shaped":{"description":{"identifier":"recipes_f68af4d0"},"tags":["crafting_table"],"pattern":["BC"],"key":{"B":{"item":"serp:dynamax_band","data":0},"C":{"item":"minecraft:purple_dye","data":0}},"result":{"item":"serp:dynamax_band_purple","count":1}}},"shapeType":"shaped","idRecipes":"serp:dynamax_band_purple"},"premium":false,"premium_users_only":false,"disable":false,"craftMap":[["","",""],["","|pa|serp_dynamax_band","|pa|minecraft_purple_dye"],["","",""]],"lock":true,"display_name":"Recipes","group_id":"root","type":"recipe","create_time":"2025-11-24T15:56:46.867"},{"item_id":"caramelos","item_name":"caramelos","item_icon":"custom/scripts.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"scripts/scripts.json","item_skin":"","data":{"name":"caramelos","scripts":"import { world } from \"@minecraft/server\";\n\nworld.afterEvents.entityHitEntity.subscribe((event) => {\n    const {damagingEntity,hitEntity} = event;\n    const caramelos = [{ identificador: 'serp:rare_candy_max', nivel: 10000, particula: \"serp:exp_max\" },\n                       { identificador: 'serp:rare_candy_xl',  nivel: 650,   particula: \"serp:exp_xl\" },\n                       { identificador: 'serp:rare_candy_l',   nivel: 450,   particula: \"serp:exp_l\" },\n                       { identificador: 'serp:rare_candy_m',   nivel: 250,   particula: \"serp:exp_m\" },        \n                       { identificador: 'serp:rare_candy_s',   nivel: 75,    particula: \"serp:exp_s\" },\n                       { identificador: 'serp:rare_candy_xs',  nivel: 55,    particula: \"serp:exp_xs\" }];\n\n    if (damagingEntity.typeId==\"minecraft:player\"&&hitEntity.typeId.startsWith(\"pokemon:p\")&&!hitEntity.hasTag(\"battle\")&&!hitEntity.hasTag(\"defeated\")){\n        const itemStack = damagingEntity?.getComponent(\"equippable\")?.getEquipment(\"Mainhand\");\n        const buscadueño = hitEntity?.getTags().find(tag => tag.startsWith(\"owner\"))?.split(\"%&%\");\n        if(buscadueño[1]!==damagingEntity.id) return;\n        const buscatag = damagingEntity?.getTags().find(tag => tag.startsWith(`team${buscadueño[2]}`));\n        let buscatag2 = buscatag.split(\"/\");\n\n       const caramelo = caramelos.find(c => c.identificador == itemStack.typeId);\n       let nivelActual = Number(buscatag2[8]);\n       if (nivelActual >= 10000) return;\n       nivelActual += caramelo.nivel;\n       if (nivelActual > 10000) nivelActual = 10000;\n       buscatag2[8] = nivelActual;\n       const nuevoTag = buscatag2.join(\"/\");\n       damagingEntity.removeTag(buscatag);\n       damagingEntity.addTag(nuevoTag);\n\n    if (itemStack.amount > 1){itemStack.amount -= 1;\n        damagingEntity?.getComponent(\"equippable\").setEquipment(\"Mainhand\", itemStack);} \n    else {damagingEntity?.getComponent(\"equippable\").setEquipment(\"Mainhand\", undefined);}\n    damagingEntity.playSound(\"serp.levelup\", hitEntity.location);\n    hitEntity.runCommand(`particle ${caramelo.particula} ~ ~1 ~`);}\n});"},"premium":false,"premium_users_only":false,"disable":false,"lock":true,"display_name":"Scripts","group_id":"root","type":"scripts","create_time":"2025-10-26T15:43:25.500"},{"item_id":"caramelos2","item_name":"caramelos2","item_icon":"custom/scripts.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_entity_dir":"scripts/scripts.json","item_skin":"","data":{"name":"caramelos2","scripts":"import { world } from \"@minecraft/server\";\n\nworld.afterEvents.entityHitEntity.subscribe((event) => {\n    const {damagingEntity,hitEntity} = event;\n    const caramelos = [{ identificador: 'serp:dynamax_candy_xl', nivel: 6, particula: \"serp:dyn_xl\" },\n                       { identificador: 'serp:dynamax_candy_l',  nivel: 4,   particula: \"serp:dyn_l\" },\n                       { identificador: 'serp:dynamax_candy_m',   nivel: 2,   particula: \"serp:dyn_m\" }];\n\n    if (damagingEntity.typeId==\"minecraft:player\"&&hitEntity.typeId.startsWith(\"pokemon:p\")&&!hitEntity.hasTag(\"battle\")&&!hitEntity.hasTag(\"defeated\")){\n        const itemStack = damagingEntity?.getComponent(\"equippable\")?.getEquipment(\"Mainhand\");\n        const buscadueño = hitEntity?.getTags().find(tag => tag.startsWith(\"owner\"))?.split(\"%&%\");\n        if(buscadueño[1]!==damagingEntity.id) return;\n        const buscatag = damagingEntity?.getTags().find(tag => tag.startsWith(`team${buscadueño[2]}`));\n        let buscatag2 = buscatag.split(\"/\");\n\n       const caramelo = caramelos.find(c => c.identificador == itemStack.typeId);\n       let nivelActual = Number(buscatag2[13]);\n       if (nivelActual >= 10) return;\n       nivelActual += caramelo.nivel;\n       if (nivelActual > 10) nivelActual = 10;\n       buscatag2[13] = nivelActual;\n       const nuevoTag = buscatag2.join(\"/\");\n       damagingEntity.removeTag(buscatag);\n       damagingEntity.addTag(nuevoTag);\n\n    if (itemStack.amount > 1){itemStack.amount -= 1;\n        damagingEntity?.getComponent(\"equippable\").setEquipment(\"Mainhand\", itemStack);} \n    else {damagingEntity?.getComponent(\"equippable\").setEquipment(\"Mainhand\", undefined);}\n    damagingEntity.playSound(\"serp.levelup\", hitEntity.location);\n    hitEntity.runCommand(`particle ${caramelo.particula} ~ ~1 ~`);}\n});"},"premium":false,"premium_users_only":false,"disable":false,"lock":true,"display_name":"Scripts","group_id":"root","type":"scripts","create_time":"2026-01-09T16:16:37.669"},{"item_id":"cb9370a8","item_name":"Recipes","item_icon":"custom/recipe.png","item_texture":"","item_skins_dir":"custom/skins/armchairs","item_icons_dir":"custom/icons/armchairs","item_e